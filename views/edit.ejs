<% layout("/layouts/boilerplate") %>

<body>
    <div class="row mt-3 mb-3">
        <div class="col-8 offset-2">
            <form method="POST" action="/listings/<%= listing._id %>?_method=PATCH">
            
            <div class="container mt-4">

                <h2>Edit Listing</h2>

                <!-- Title -->
                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input 
                        type="text" 
                        name="title" 
                        class="form-control" 
                        value="<%= listing.title %>" 
                        required>
                </div>

                <!-- Image URL -->
                <div class="mb-3">
                    <label class="form-label">Image URL</label>
                    <input 
                        type="text" 
                        name="image" 
                        class="form-control" 
                        value="<%= listing.image %>">
                </div>

                <!-- Description -->
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea 
                        name="description" 
                        class="form-control" 
                        rows="4" 
                        required><%= listing.description %></textarea>
                </div>

                <!-- Price -->
                <div class="mb-3">
                    <label class="form-label">Price</label>
                    <input 
                        type="number" 
                        name="price" 
                        class="form-control" 
                        value="<%= listing.price %>" 
                        required>
                </div>
                <div class="row">
                    <div class="col-6">
                          <!-- Location -->
                        <div class="mb-3">
                            <label class="form-label">Location</label>
                            <input 
                                type="text" 
                                name="location" 
                                class="form-control" 
                                value="<%= listing.location %>" 
                                required>
                        </div>

                    </div>
                    <div class="col-6">
                             <!-- Country -->
                <div class="mb-3">
                    <label class="form-label">Country</label>
                    <input 
                        type="text" 
                        name="country" 
                        class="form-control" 
                        value="<%= listing.country %>" 
                        required>
                </div>
                    </div>
                </div>
              
               

                <!-- Submit -->
                <button type="submit" class="btn btn-primary" style="background-color: #fe424d;">Update Listing</button>
                
            </div>
        </form>
        </div>
    </div>
   
</body>
</html>