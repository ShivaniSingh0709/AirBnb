<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <title>Home</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <h2 class="show-heading">Its Very nice cottage at <%=listing.location %>,<%= listing.country %></h2>
<div class="container listing-item">
    <%=listing.id%>
  <% if (listing) { %>
    <img src="<%= listing.image %>" class="listing-image" />

    <h2><%= listing.title %></h2>
    <p class="description"><%= listing.description %></p>
    <p class="price">&#8377;<%= listing.price %></p>
    <p class="location"><%= listing.location %></p>
    <p class="country"><%= listing.country %></p>

    <a href="/listings/<%= listing.id %>/edit"><button class="btn btn-info">Edit Details</button></a>
      <form action="/listings/<%=listing.id%>?_method=DELETE" method="POST">
            <button type="submit" class="btn btn-danger">Delete</button>
         </form>
<% } else { %>
    <p>No data found</p>
<% } %>
    </div>
</body>
</html>